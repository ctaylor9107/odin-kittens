<h1>Check Out This Kitten!</h1>

<h2><%= @kitten.name %></h2>

<ul>
    <li>Age: <%= @kitten.age %></li>
    <li>Cutesness: <%= @kitten.cuteness %></li>
    <li>Softness: <%= @kitten.softness %></li>
</ul>

<%= link_to "Update this Kitten's info?", edit_kitten_path %><br><br>

<%= link_to "Remove Kitten", kitten_path(@kitten), data: {
                    turbo_method: :delete,
                    turbo_confirm: "Are you sure you want to remove this adorable kitten??"
                  } %>